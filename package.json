{
  "name": "sv40kserien-frontend-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build:dev": "copy .env.development .env && npx expo export --platform web --output-dir dist --clear",
    "build:staging": "copy .env.staging .env && npx expo export --platform web --output-dir dist --clear",
    "build:prod": "copy .env.prod .env && npx expo export --platform web --output-dir dist --clear",
    "deploy:staging": "npm run build:staging && aws s3 sync dist/ s3://wha-client-staging-web-app --delete && aws cloudfront create-invalidation --distribution-id E3BF09I57S5OM3 --paths \"/*\"",
    "deploy:prod": "npm run build:prod && aws s3 sync dist/ s3://wha-client-prod-web-app --delete && aws cloudfront create-invalidation --distribution-id E3LQWVNXRIL22Z --paths \"/*\""
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/drawer": "^7.1.1",
    "@react-navigation/native": "^7.0.0",
    "@supabase/supabase-js": "^2.93.3",
    "@tanstack/react-query": "^5.76.1",
    "axios": "^1.11.0",
    "dom-to-image": "^2.6.0",
    "dotenv": "^16.5.0",
    "expo": "~54.0.31",
    "expo-asset": "~12.0.12",
    "expo-auth-session": "~7.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.6",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-media-library": "~18.2.1",
    "expo-router": "~6.0.21",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "jwt-decode": "^4.0.0",
    "moti": "^0.30.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.2",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-view-shot": "~4.0.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets-core": "^1.6.2"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@eslint/js": "^9.23.0",
    "@types/react": "^19.1.0",
    "@types/react-native": "^0.72.8",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "eslint": "^9.23.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-native": "^5.0.0",
    "json-server": "^1.0.0-beta.3",
    "react-native-svg-transformer": "^1.5.3",
    "typescript": "~5.8.3"
  },
  "private": true
}
